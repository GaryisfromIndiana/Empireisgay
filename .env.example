EMPIRE_ANTHROPIC_API_KEY=sk-ant-...
EMPIRE_OPENAI_API_KEY=sk-...
EMPIRE_FLASK_SECRET_KEY=change-me-to-random-string
EMPIRE_FLASK_DEBUG=true
EMPIRE_DB_URL=sqlite:///empire.db
EMPIRE_TAVILY_API_KEY=tvly-...

# MCP Servers — external tools for lieutenants
# Fetch server (reads any URL):
EMPIRE_MCP__SERVERS={"fetch": {"command": ["npx", "-y", "@modelcontextprotocol/server-fetch"]}}
# Multiple servers example:
# EMPIRE_MCP__SERVERS={"fetch": {"command": ["npx", "-y", "@modelcontextprotocol/server-fetch"]}, "github": {"command": ["npx", "-y", "@modelcontextprotocol/server-github"], "env": {"GITHUB_TOKEN": "ghp_..."}}}
